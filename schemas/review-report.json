{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mrrobot0985.dev/schemas/review-report.json",
  "title": "Multi-Perspective Review Report",
  "description": "Schema for aggregate and per-perspective review reports produced by the sandcastle review system.",
  "type": "object",
  "required": ["run_id", "target_ref", "base_ref", "timestamp", "overall", "perspectives", "summary"],
  "properties": {
    "run_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this review run."
    },
    "target_ref": {
      "type": "string",
      "description": "The branch, tag, or commit under review."
    },
    "base_ref": {
      "type": "string",
      "description": "The reference used as the comparison baseline."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the report was generated."
    },
    "overall": {
      "type": "string",
      "enum": ["pass", "fail"],
      "description": "Aggregated gate result."
    },
    "perspectives": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/perspective" }
    },
    "summary": {
      "$ref": "#/definitions/summary"
    }
  },
  "definitions": {
    "perspective": {
      "type": "object",
      "required": ["name", "status", "exit_code", "duration_ms", "findings"],
      "properties": {
        "name": {
          "type": "string",
          "enum": ["correctness", "architecture", "safety"]
        },
        "status": {
          "type": "string",
          "enum": ["pass", "warn", "fail"]
        },
        "exit_code": {
          "type": "integer"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "findings": {
          "type": "array",
          "items": { "$ref": "#/definitions/finding" }
        }
      }
    },
    "finding": {
      "type": "object",
      "required": ["perspective", "severity", "rule", "message"],
      "properties": {
        "perspective": {
          "type": "string",
          "enum": ["correctness", "architecture", "safety"]
        },
        "severity": {
          "type": "string",
          "enum": ["critical", "warning", "info"]
        },
        "rule": {
          "type": "string",
          "description": "Machine-readable rule identifier."
        },
        "file": {
          "type": ["string", "null"]
        },
        "line": {
          "type": ["integer", "null"]
        },
        "message": {
          "type": "string"
        },
        "suggestion": {
          "type": ["string", "null"]
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["critical", "warning", "info"],
      "properties": {
        "critical": { "type": "integer", "minimum": 0 },
        "warning": { "type": "integer", "minimum": 0 },
        "info": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
