{
    "default": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "git-hooks-manager": {}
        }
    },
    "with-commitlint": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "git-hooks-manager": {
                "hooks": "pre-commit,commitlint"
            }
        }
    }
}
