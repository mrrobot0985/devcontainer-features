{
    "default": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "direnv-integration": {}
        }
    },
    "bash-hook": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "direnv-integration": {
                "shell": "bash"
            }
        }
    },
    "auto-allow": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "direnv-integration": {
                "autoAllow": true
            }
        }
    }
}
