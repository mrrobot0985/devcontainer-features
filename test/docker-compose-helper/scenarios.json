{
    "default": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "docker-compose-helper": {}
        }
    },
    "validate-only": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "docker-compose-helper": {
                "validate": true,
                "healthChecks": false,
                "dependsOnOrdering": false
            }
        }
    }
}
