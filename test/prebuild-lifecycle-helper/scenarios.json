{
    "warn-only": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "prebuild-lifecycle-helper": {
                "failOnWarning": false
            }
        }
    },
    "fail-on-warning": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "prebuild-lifecycle-helper": {
                "failOnWarning": true
            }
        }
    },
    "detect-npm": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "prebuild-lifecycle-helper": {
                "failOnWarning": false,
                "detectLanguages": "node"
            }
        }
    },
    "fix-mode": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "prebuild-lifecycle-helper": {
                "fixMode": true,
                "detectLanguages": "node"
            }
        }
    }
}
