{
    "default": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "postgres-dev": {}
        }
    },
    "with-version": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "postgres-dev": {
                "version": "16",
                "installPgFormatter": true,
                "installPgTop": true
            }
        }
    }
}
