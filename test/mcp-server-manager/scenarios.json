{
    "default": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "mcp-server-manager": {}
        }
    },
    "multi-server": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "mcp-server-manager": {
                "servers": "github,playwright,fetch"
            }
        }
    },
    "unknown-server-skipped": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "mcp-server-manager": {
                "servers": "github,not-a-real-server,memory"
            }
        }
    }
}
