{
    "default": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "ghcr.io/devcontainers/features/python:1": {},
            "dbt-transform": {}
        }
    },
    "with-adapters": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "ghcr.io/devcontainers/features/python:1": {},
            "dbt-transform": {
                "installDuckdbAdapter": true,
                "installPostgresAdapter": true
            }
        }
    }
}
