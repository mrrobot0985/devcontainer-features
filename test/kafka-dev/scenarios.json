{
    "default": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "kafka-dev": {}
        }
    },
    "with-confluent": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "kafka-dev": {
                "installKcat": true,
                "installConfluentCli": true
            }
        }
    }
}
