{
    "claude_stack": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "ghcr.io/devcontainers/features/node:1": {
                "version": "20"
            },
            "ghcr.io/anthropics/devcontainer-features/claude-code:1": {},
            "claude-code-privacy": {},
            "claude-code-backend": {
                "baseUrl": "http://ollama:11434",
                "models": "sonnet:qwen2.5"
            },
            "claude-code-hooks": {},
            "claude-code-skills": {
                "skipOnFailure": true
            },
            "claude-code-plugins": {
                "skipOnFailure": true
            },
            "container-firewall": {
                "blockTelemetry": true
            }
        }
    },
    "agent_security_floor": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "remoteUser": "vscode",
        "features": {
            "non-root-enforcer": {
                "failOnWarning": false
            },
            "ai-agent-sandbox": {
                "preset": "moderate",
                "failOnWarning": false
            },
            "container-firewall": {
                "services": "multi-ai",
                "dryRun": true
            }
        }
    }
}
