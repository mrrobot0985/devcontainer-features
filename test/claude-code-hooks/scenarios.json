{
    "no_statusline": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "claude-code-hooks": {
                "installStatusLine": false
            }
        }
    },
    "session_only": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "claude-code-hooks": {
                "installSessionHooks": true,
                "installAgentHooks": false,
                "installTurnHooks": false,
                "installStatusLine": true
            }
        }
    },
    "agent_only": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "claude-code-hooks": {
                "installSessionHooks": false,
                "installAgentHooks": true,
                "installTurnHooks": false,
                "installStatusLine": false
            }
        }
    },
    "turn_only": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "claude-code-hooks": {
                "installSessionHooks": false,
                "installAgentHooks": false,
                "installTurnHooks": true,
                "installStatusLine": false
            }
        }
    },
    "block_dangerous": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "claude-code-hooks": {
                "installSessionHooks": false,
                "installAgentHooks": true,
                "installTurnHooks": false,
                "installStatusLine": false,
                "blockDangerousCommands": true
            }
        }
    },
    "custom_denylist": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "claude-code-hooks": {
                "installSessionHooks": false,
                "installAgentHooks": true,
                "installTurnHooks": false,
                "installStatusLine": false,
                "blockDangerousCommands": true,
                "dangerousCommandDenylist": "curl[[:space:]]+https://evil\\.com,curl[[:space:]]+http://evil\\.com"
            }
        }
    }
}
