{
    "default": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "ghcr.io/devcontainers/features/node:1": {
                "version": "20"
            },
            "ghcr.io/anthropics/devcontainer-features/claude-code:1": {},
            "claude-code-plugins": {
                "skipOnFailure": true
            }
        }
    },
    "ralph-loop": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "ghcr.io/devcontainers/features/node:1": {
                "version": "20"
            },
            "ghcr.io/anthropics/devcontainer-features/claude-code:1": {},
            "claude-code-plugins": {
                "enableRalphLoop": true,
                "skipOnFailure": true
            }
        }
    },
    "custom-plugins": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "ghcr.io/devcontainers/features/node:1": {
                "version": "20"
            },
            "ghcr.io/anthropics/devcontainer-features/claude-code:1": {},
            "claude-code-plugins": {
                "customPlugins": "quickdesign@claude-community",
                "skipOnFailure": true
            }
        }
    }
}
