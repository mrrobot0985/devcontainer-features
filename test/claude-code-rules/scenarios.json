{
    "default": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "claude-code-rules": {}
        }
    },
    "safety_only": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
