{
    "github": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "container-firewall": {
                "services": "github"
            }
        }
    },
    "custom": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "container-firewall": {
                "services": "minimal",
                "extraDomains": "api.github.com"
            }
        }
    },
    "telemetry": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "container-firewall": {
                "services": "claude-code",
                "blockTelemetry": true
            }
        }
    },
    "composition": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "container-firewall": {
                "services": "github,pypi"
            }
        }
    }
}
