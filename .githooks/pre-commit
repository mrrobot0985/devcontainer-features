#!/bin/bash
set -euo pipefail

# Pre-commit hook: keep every src/<feature>/README.md in sync with its
# devcontainer-feature.json metadata.
#
# Install once with:
#   git config core.hooksPath .githooks
#
# The same checks run in CI via the readme-sync job in
# .github/workflows/validate.yml, so drift that passes this hook will also
# pass CI.

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"

# Generate any missing READMEs from devcontainer-feature.json files.
uv run python scripts/generate-feature-readmes.py

# If new READMEs were created (untracked), stage them and abort so the user reviews.
if git ls-files --others --exclude-standard | grep -qE '^src/.*/README\.md$'; then
    echo ""
    echo "Generated new feature README(s):"
    git ls-files --others --exclude-standard | grep -E '^src/.*/README\.md$'
    echo ""
    echo "Review the generated files, then stage and commit again:"
    echo "  git add src/*/README.md"
    echo "  git commit -m '...'"
    exit 1
fi

# Fail when devcontainer-feature.json is staged but README.md is not.
# This catches edits where the generator updated an existing README but the
# user forgot to stage it.
STAGED_JSONS=$(git diff --cached --name-only --diff-filter=ACM | grep 'devcontainer-feature\.json$' || true)
if [ -n "$STAGED_JSONS" ]; then
    MISSING_README_UPDATES=""
    for json_file in $STAGED_JSONS; do
        readme_file="$(dirname "$json_file")/README.md"
        if ! git diff --cached --name-only | grep -Fxq "$readme_file"; then
            MISSING_README_UPDATES="${MISSING_README_UPDATES}\n  - ${readme_file} (not staged with ${json_file})"
        fi
    done
    if [ -n "$MISSING_README_UPDATES" ]; then
        echo ""
        echo "ERROR: The following devcontainer-feature.json files are staged"
        echo "but their README.md counterparts are not. Stage README updates before committing:"
        printf '%b\n' "$MISSING_README_UPDATES"
        echo ""
        exit 1
    fi
fi

# --- Docs markdown formatting check ---
STAGED_MD=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^docs/.*\.md$' || true)
if [ -n "$STAGED_MD" ]; then
    if command -v uv >/dev/null 2>&1; then
        if ! uvx --with mdformat-gfm mdformat --check $STAGED_MD; then
            echo ""
            echo "ERROR: Staged markdown files in docs/ are not properly formatted."
            echo "Run the following to fix them:"
            echo "  uvx --with mdformat-gfm mdformat $STAGED_MD"
            echo "Then stage the changes and commit again."
            exit 1
        fi
    elif command -v mdformat >/dev/null 2>&1; then
        if ! mdformat --check $STAGED_MD; then
            echo ""
            echo "ERROR: Staged markdown files in docs/ are not properly formatted."
            echo "Run the following to fix them:"
            echo "  mdformat $STAGED_MD"
            echo "Then stage the changes and commit again."
            exit 1
        fi
    else
        echo ""
        echo "WARNING: mdformat is not installed. Skipping markdown format check."
        echo "Install it with: uv tool install mdformat-gfm"
        echo ""
    fi
fi

exit 0
