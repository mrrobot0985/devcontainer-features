{
  "id": "claude-code-skills-matt-pocock",
  "name": "Claude Code Matt Pocock Skills",
  "version": "0.1.1",
  "description": "Clones Matt Pocock's skills into ~/.claude/skills/ with selectable categories",
  "options": {
    "installEngineering": {
      "type": "boolean",
      "default": true,
      "description": "Install engineering skills"
    },
    "installProductivity": {
      "type": "boolean",
      "default": true,
      "description": "Install productivity skills"
    },
    "installMisc": {
      "type": "boolean",
      "default": false,
      "description": "Install miscellaneous skills"
    },
    "installPersonal": {
      "type": "boolean",
      "default": false,
      "description": "Install personal skills"
    }
  },
  "installsAfter": [
    "ghcr.io/devcontainers/features/common-utils",
    "ghcr.io/devcontainers/features/git",
    "ghcr.io/anthropics/devcontainer-features/claude-code"
  ]
}
