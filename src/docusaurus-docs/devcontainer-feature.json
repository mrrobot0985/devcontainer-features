{
  "id": "docusaurus-docs",
  "name": "Docusaurus Documentation Site",
  "version": "1.0.0",
  "description": "Installs Docusaurus for building documentation websites in devcontainers",
  "options": {
    "version": {
      "type": "string",
      "default": "latest",
      "description": "Version of @docusaurus/core to install, or 'latest'"
    },
    "initTemplate": {
      "type": "string",
      "default": "classic",
      "enum": ["classic", "classic-typescript", "fast"],
      "description": "Template to use when initializing a new Docusaurus site"
    }
  },
  "installsAfter": [
    "ghcr.io/devcontainers/features/node"
  ],
  "documentationURL": "https://github.com/mrrobot0985/devcontainer-features/tree/main/src/docusaurus-docs"
}
