    "domains": ["api.x.ai"]
  },
  "openai": {
    "domains": ["api.openai.com"]
  },
  "vscode": {
    "domains": [
      "marketplace.visualstudio.com",
      "vscode.blob.core.windows.net",
      "update.code.visualstudio.com"
    ]
  },
  "apt": {
    "domains": [
      "deb.debian.org",
      "security.debian.org",
      "archive.ubuntu.com",
      "security.ubuntu.com"
    ]
  },
  "docker": {
    "domains": ["registry-1.docker.io", "production.cloudflare.docker.com"]
