{
  "id": "pandoc-convert",
  "version": "1.0.1",
  "name": "Pandoc Document Converter",
  "description": "Installs Pandoc universal document converter with optional LaTeX support",
  "documentationURL": "https://github.com/BrainXio/devcontainer-features/tree/main/features/src/pandoc-convert",
  "licenseURL": "https://github.com/BrainXio/devcontainer-features/blob/main/LICENSE",
  "options": {
    "version": {
      "type": "string",
      "default": "latest",
      "description": "Pandoc version to install (e.g., 3.1.11, latest)"
    },
    "installLatex": {
      "type": "boolean",
      "default": false,
      "description": "Install TeX Live for PDF generation support"
    }
  },
  "installsAfter": [
    "ghcr.io/devcontainers/features/common-utils"
  ]
}
